# Filmwaker — .htaccess

RewriteEngine On

# 1. Forza HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Redirect non-www → www
RewriteCond %{HTTP_HOST} ^filmwaker\.it$ [NC]
RewriteRule ^(.*)$ https://www.filmwaker.it/$1 [R=301,L]

# 3. Pagina principale
DirectoryIndex index.html
